generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AppStatus {
  PENDING
  APPROVED
  DENIED
}

enum PlanTier {
  BASIC
  MID
  PREMIUM
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  image         String?
  role          Role         @default(USER)
  plan          PlanTier     @default(BASIC)

  company       String?
  phone         String?
  isOnboarded   Boolean      @default(false)

  createdAt     DateTime     @default(now())

  applications  Application[]
}

model Invite {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  plan      PlanTier
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Application {
  id          String     @id @default(cuid())
  name        String
  company     String
  email       String
  comments    String?
  desiredPlan PlanTier
  status      AppStatus  @default(PENDING)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  userId      String?
  user        User? @relation(fields: [userId], references: [id])

  @@index([email])
  @@index([status])
}