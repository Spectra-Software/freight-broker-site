generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  USER
  ADMIN
}

enum AppStatus {
  PENDING
  APPROVED
  DENIED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  image     String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  applications Application[]
}

model Application {
  id         String     @id @default(cuid())
  firstName  String
  lastName   String
  company    String
  email      String
  phone      String
  status     AppStatus  @default(PENDING)
  createdAt  DateTime   @default(now())

  userId     String?
  user       User?      @relation(fields: [userId], references: [id])
}